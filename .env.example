# Linesia website — environment variables
# Copy to .env.local and fill. Never commit .env.local.

# ─── Postgres (shared DB) ───
# Le site se connecte via PgBouncer en local (port 6432).
DATABASE_URL=postgres://linesia_web:CHANGEME@127.0.0.1:6432/linesia
# Connexion directe (port 5432) pour LISTEN/NOTIFY uniquement — pgbouncer
# en mode transaction ne supporte pas les notifications.
DATABASE_URL_DIRECT=postgres://linesia_web:CHANGEME@127.0.0.1:5432/linesia
PG_POOL_MAX=20

# ─── API ↔ plugin (legacy, garder pendant la transition) ───
ANALYTICS_API_KEY=CHANGEME-rotate-in-prod
ANALYTICS_API_URL=http://localhost:3000

# ─── OAuth ───
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT=http://localhost:3000/api/auth/discord/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT=http://localhost:3000/api/auth/microsoft/callback

# ─── Misc ───
ADMIN_PASSWORD=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
